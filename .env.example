# Copy this file to .env and fill in the values from your Supabase project's
# Project Settings -> API page. The anon key is safe to ship in a client bundle
# (access is enforced by Postgres Row Level Security, not by keeping this secret)
# but it's still kept out of git here for hygiene/rotation reasons.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# RevenueCat public SDK keys (RevenueCat dashboard > Project Settings > API keys).
# These are meant to be embedded in the client, like the Supabase anon key above.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=
